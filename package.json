{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:web": "vite build",
    "start": "cross-env NODE_ENV=production npx tsx server.ts",
    "keepalive": "node scripts/keepalive.cjs",
    "mobile:sync": "npm run build:web && npx cap sync",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "desktop:start": "npm run build:web && electron ./electron/main.cjs",
    "desktop:build": "npm run build:web && electron-builder -w",
    "migrate:supabase": "tsx scripts/migrate-db-to-supabase.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.edenify.app",
    "productName": "Edenify",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.ts",
      "db.json",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-schedule": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
