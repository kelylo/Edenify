# GEMINI keys used by Edenify.
# The app rotates across GEMINI_API_KEY_1 and GEMINI_API_KEY_2,
# and falls back to GEMINI_API_KEY if needed.
GEMINI_API_KEY_1="MY_GEMINI_API_KEY_1"
GEMINI_API_KEY_2="MY_GEMINI_API_KEY_2"
GEMINI_API_KEY="MY_GEMINI_API_KEY_FALLBACK"

# Local app port (avoid browser-unsafe ports like 6000)
PORT=6001

# Supabase client config
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
# Backend-only key used by server routes for secure reads/writes
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
# Frontend-safe values consumed by Vite client bundle
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
# Do not expose DB password to client; keep server-side only if needed
SUPABASE_DB_PASSWORD="YOUR_SERVER_SIDE_DB_PASSWORD"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional future integrations
RESEND_API_KEY="MY_RESEND_API_KEY"
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# Render picks PORT automatically. Do not hardcode it in Render dashboard.
