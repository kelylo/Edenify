TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Optional timezone label used in replies (example: Africa/Lagos)
BOT_TIMEZONE=UTC
# Run mode:
# - daemon: long-running bot process (default)
# - once: process updates/reminders once and exit (for cron jobs)
# BOT_RUN_MODE=daemon
# Optional custom data path for todo storage JSON
# BOT_STORE_PATH=./data/store.json
# Optional custom Bible plan path. Default points to ./data/bible-plan.json
# BIBLE_PLAN_PATH=./data/bible-plan.json
# Optional custom Bible database path. Default points to ./data/bible-data.json
# BIBLE_DB_PATH=./data/bible-data.json
