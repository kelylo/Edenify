# Repository-level environment template for split deployment

# ---------- Frontend (Cloudflare Pages / frontend) ----------
VITE_API_BASE_URL="https://your-backend.up.railway.app"
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# Local frontend development example
# VITE_API_BASE_URL="http://localhost:6001"

# ---------- Backend (Railway / backend) ----------
PORT=6001
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_KEY"

# Optional compatibility / fallback keys
SUPABASE_KEY=""
GEMINI_API_KEY_1=""
GEMINI_API_KEY_2=""
OPENAI_API_KEY=""

# Optional CORS allow-list (comma-separated)
CORS_ORIGIN="https://your-frontend.pages.dev"

# Local backend development example
# CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
